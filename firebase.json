{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/quran/page/:number",
        "destination": "/quran/page?number=:number",
        "type": 302
      },
      {
        "source": "/quran/surah/:id",
        "destination": "/quran/surah?id=:id",
        "type": 302
      }
    ],
    "frameworksBackend": {
      "region": "europe-west1"
    }
  }
}
